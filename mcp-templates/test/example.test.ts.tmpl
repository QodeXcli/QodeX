import { describe, it, expect } from 'vitest';
import { exampleHandler, exampleTool } from '../src/tools/example.js';

describe('{{NAME}} :: example tool', () => {
  it('advertises the right name', () => {
    expect(exampleTool.name).toBe('example');
  });

  it('echoes the message', async () => {
    const r = await exampleHandler({ message: 'hi' });
    expect(r.isError).toBeFalsy();
    expect(r.content[0]!.text).toContain('hi');
  });

  it('rejects missing args', async () => {
    await expect(exampleHandler({})).rejects.toThrow();
  });
});
